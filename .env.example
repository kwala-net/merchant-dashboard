# Upstash Redis (required for runtime data persistence)
UPSTASH_REDIS_REST_URL="https://<your-db>.upstash.io"
UPSTASH_REDIS_REST_TOKEN=""

# Sepolia RPC — get a free key at https://alchemy.com or https://infura.io
SEPOLIA_RPC_URL="https://eth-sepolia.g.alchemy.com/v2/<your-key>"

# Etherscan API key — for --verify during forge deploy (https://etherscan.io/myapikey)
ETHERSCAN_API_KEY=""

# Deployer private key — hex with or without 0x prefix
PRIVATE_KEY=""

# Set these AFTER running: forge script script/Deploy.s.sol:Deploy ...
MERCHANT_PAYMENTS_ADDRESS=""
MOCK_ERC20_ADDRESS=""
